{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "before/after gallery slider (spec/02-content-model.md §6)",
  "type": "object",
  "required": ["cat", "title", "sub", "before", "after"],
  "properties": {
    "cat": { "type": "string" },
    "title": { "type": "string" },
    "sub": { "type": "string" },
    "before": {
      "type": "object",
      "required": ["src", "alt"],
      "properties": { "src": { "type": "string" }, "alt": { "type": "string" } },
      "additionalProperties": false
    },
    "after": {
      "type": "object",
      "required": ["src", "alt"],
      "properties": { "src": { "type": "string" }, "alt": { "type": "string" } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
